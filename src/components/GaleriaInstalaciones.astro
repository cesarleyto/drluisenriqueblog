<section class="galeria-section">
  <div class="galeria-grid">
    
    <!-- Foto 1 -->
    <div class="galeria-item cursor-pointer">
      <img 
        src="/assets/images/hospital1.jpg" 
        alt="Instalaciones Dr. Luis Enrique Guadalupe Rojas 1"
        class="galeria-img"
        loading="lazy"
        data-gallery-item
      />
      <div class="galeria-overlay"></div>
    </div>

    <!-- Foto 2 -->
    <div class="galeria-item cursor-pointer">
      <img 
        src="/assets/images/hospital2.jpg" 
        alt="Instalaciones Dr. Luis Enrique Guadalupe Rojas 2"
        class="galeria-img"
        loading="lazy"
        data-gallery-item
      />
      <div class="galeria-overlay"></div>
    </div>

    <!-- Foto 3 -->
    <div class="galeria-item cursor-pointer">
      <img 
        src="/assets/images/hospital3.jpg" 
        alt="Instalaciones Dr. Luis Enrique Guadalupe Rojas 3"
        class="galeria-img"
        loading="lazy"
        data-gallery-item
      />
      <div class="galeria-overlay"></div>
    </div>

    <!-- Foto 4 -->
    <div class="galeria-item cursor-pointer">
      <img 
        src="/assets/images/hospital4.jpg" 
        alt="Instalaciones Dr. Luis Enrique Guadalupe Rojas 4"
        class="galeria-img"
        loading="lazy"
        data-gallery-item
      />
      <div class="galeria-overlay"></div>
    </div>

  </div>

  <!-- Lightbox Modal -->
  <div id="lightbox" class="lightbox hidden">
    <button class="lightbox-close" aria-label="Cerrar">&times;</button>
    <img id="lightbox-img" src="" alt="Vista ampliada" class="lightbox-content animate-fade-in" />
  </div>
</section>

<style>
  /* Layout & Grid */
  .galeria-section {
    width: 100%;
    overflow: hidden;
    background-color: var(--bg-white);
  }

  .galeria-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0; /* Sin espacio entre las fotos para que se vea como mosaico */
  }

  /* Ítems e Imágenes */
  .galeria-item {
    position: relative;
    aspect-ratio: 1 / 1; /* Esto hace que sean cuadrados perfectos (aspect-square) */
    overflow: hidden;
    cursor: pointer;
  }

  .galeria-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s ease-in-out;
  }

  /* Efecto zoom al pasar el mouse */
  .galeria-item:hover .galeria-img {
    transform: scale(1.1);
  }

  /* Overlay turquesa sutil al pasar el mouse */
  .galeria-overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(20, 184, 166, 0.15); 
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .galeria-item:hover .galeria-overlay {
    opacity: 1;
  }

  /* =========================================
     Lightbox Modal
  ========================================= */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background-color: rgba(15, 23, 42, 0.95); /* Fondo oscuro semitransparente */
    backdrop-filter: blur(5px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    cursor: zoom-out;
  }

  .lightbox.hidden {
    display: none;
  }

  .lightbox-content {
    max-width: 100%;
    max-height: 90vh;
    border-radius: var(--radius-lg);
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    object-fit: contain;
    cursor: default; /* El puntero cambia dentro de la imagen */
  }

  .lightbox-close {
    position: absolute;
    top: 20px;
    right: 30px;
    background: none;
    border: none;
    color: white;
    font-size: 3.5rem;
    font-weight: 300;
    cursor: pointer;
    transition: color 0.3s ease;
    line-height: 1;
  }

  .lightbox-close:hover {
    color: var(--primary);
  }

  /* Animación del Lightbox */
  @keyframes fadeIn {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
  }
  
  .animate-fade-in {
    animation: fadeIn 0.4s ease-out forwards;
  }

  /* Móviles y Tablets */
  @media (max-width: 768px) {
    .galeria-grid {
      grid-template-columns: repeat(2, 1fr); /* 2x2 en celular */
    }
  }
</style>

<script>
  // En Astro, los scripts se ejecutan automáticamente
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img');
  const galleryItems = document.querySelectorAll('[data-gallery-item]');
  const closeBtn = document.querySelector('.lightbox-close');

  // Abrir Lightbox
  galleryItems.forEach(item => {
    item.addEventListener('click', () => {
      if (lightbox && lightboxImg) {
        // Tomamos el src directamente de la etiqueta img que se clickeó
        lightboxImg.src = item.src;
        lightbox.classList.remove('hidden');
        document.body.style.overflow = 'hidden'; // Bloquea el scroll del fondo
      }
    });
  });

  // Cerrar Lightbox
  const closeLightbox = () => {
    if(lightbox) {
      lightbox.classList.add('hidden');
      document.body.style.overflow = ''; // Libera el scroll
    }
  };

  closeBtn?.addEventListener('click', closeLightbox);
  
  // Cerrar si se da click afuera de la imagen
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  // Cerrar con la tecla Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });
</script>