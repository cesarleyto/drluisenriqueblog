<style>
  /* El Fondo Degradado */
  .section-gradient {
    background: radial-gradient(circle at center, rgba(20, 184, 166, 0.18) 0%, rgba(20, 184, 166, 0.05) 40%, rgba(255, 255, 255, 1) 80%);
    padding: 80px 0;
  }

  .section-header h2 {
    font-size: 2.2rem;
    color: var(--primary);
    margin-bottom: 3.5rem;
    line-height: 1.2;
  }

  .consultorio-container {
    display: flex;
    align-items: center;
    gap: 50px;
  }

  .consultorio-info, .consultorio-mapa {
    flex: 1;
  }

  .consultorio-info h3 {
    font-size: 1.6rem;
    color: var(--secondary);
    margin-bottom: 0.8rem;
  }

  .direccion-texto {
    color: var(--text-dark);
    font-size: 1.05rem;
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .divider {
    height: 1px;
    background-color: rgba(0,0,0,0.1);
    margin: 50px 0;
    width: 100%;
  }

  .otros-medios {
    margin-top: 50px;
    max-width: 600px; /* Para que los botones extra queden centrados y no se estiren */
    margin-left: auto;
    margin-right: auto;
  }

  /* Grid de botones de contacto */
  .contact-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr); 
    gap: 15px;
  }

  /* Estilos de cada botón */
  .btn-contacto {
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--bg-white); 
    padding: 12px 16px;
    border-radius: var(--radius-md);
    border: 2px solid #e2e8f0; 
    text-decoration: none;
    color: var(--text-dark);
    transition: all 0.3s ease;
  }

  .btn-contacto:hover {
    border-color: var(--primary);
    box-shadow: 0 8px 15px rgba(20, 184, 166, 0.15);
    transform: translateY(-2px);
  }

  .icono-btn {
    width: 28px;
    height: 28px;
    color: var(--primary); 
    flex-shrink: 0;
  }

  .datos-btn {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .numero {
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--secondary);
    line-height: 1.2;
  }

  .etiqueta {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  /* Estilos para el iframe de Google Maps */
  .map-iframe {
    width: 100%;
    height: 350px;
    border: none;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  /* Sello URAC */
  .urac-container {
    margin-top: 60px; 
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .logo-urac {
    max-width: 350px; 
    width: 100%;
    height: auto;
    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); 
  }

  .logo-urac:hover {
    transform: scale(1.08); 
  }

  /* Ajustes Móviles */
  @media (max-width: 968px) {
    .consultorio-container { 
      flex-direction: column; 
    }
    
    /* Regresamos el orden natural en móviles (Texto arriba, mapa abajo) */
    .order-1 { order: 2; }
    .order-2 { order: 1; }

    .contact-grid {
      grid-template-columns: 1fr; 
    }

    .section-header h2 {
      font-size: 1.8rem;
    }
    
    .map-iframe {
      height: 300px; 
    }

    .urac-container {
      margin-top: 40px;
    }
  }
</style>