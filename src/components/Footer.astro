<style>
  .footer {
    background-color: var(--primary);
    color: #ffffff;
    padding: 50px 0 20px;
    margin-top: auto;
  }
  
  /* Aquí está la magia: apuntamos directo a todos los párrafos del footer y los forzamos a ser blancos */
  .footer p {
    color: #ffffff !important;
  }

  .footer-address {
    margin-bottom: 1.5rem;
    font-size: 1rem;
  }

  /* Contenedor Flex para alinear los botones al centro */
  .footer-contact-buttons {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    margin-bottom: 2rem;
    flex-wrap: wrap; 
  }

  /* Estilos del Botón Digital de alto contraste */
  .btn-footer-contact {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: linear-gradient(135deg, #ffffff 0%, #f1f5f9 100%);
    color: var(--primary); 
    padding: 10px 24px;
    border-radius: 50px;
    border: none;
    font-size: 0.95rem;
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15); 
    transition: all 0.3s ease;
  }

  .btn-footer-contact:hover {
    background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);
    transform: translateY(-3px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.25);
  }

  .copy {
    border-top: 1px solid rgba(255, 255, 255, 0.15); 
    padding-top: 20px;
    font-size: 0.85rem;
  }
  
  .copy p {
    margin: 0;
  }
</style>