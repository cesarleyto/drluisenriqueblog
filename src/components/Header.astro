<style>
  .header {
    background-color: var(--bg-white);
    box-shadow: var(--shadow-sm);
    position: sticky;
    top: 0;
    z-index: 1000;
    padding: 25px 0; 
    transition: all 0.4s ease; 
  }
  
  .header.scrolled {
    padding: 10px 0; 
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08); 
  }
  
  .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: relative;
  }
  
  .logo {
    display: flex;
    align-items: center;
  }
  
  .logo-img {
    height: 80px; 
    width: auto;
    max-width: 450px; 
    object-fit: contain;
    transition: height 0.4s ease; 
  }
  
  .header.scrolled .logo-img {
    height: 65px; 
  }
  
  .nav-right {
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  
  .nav-links {
    display: flex;
    gap: 1.5rem;
  }
  
  .nav-links a {
    font-weight: 500;
    color: var(--text-dark);
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  
  .nav-links a::after {
    display: block;
    content: attr(data-text);
    font-weight: 700;
    height: 0;
    overflow: hidden;
    visibility: hidden;
  }
  
  .nav-links a:hover {
    color: var(--secondary);
    font-weight: 700;
  }

  .social-links {
    display: flex;
    align-items: center;
    gap: 1rem;
    border-right: 1px solid #e5e7eb; 
    padding-right: 1.5rem;
  }
  
  .social-links a {
    color: var(--text-muted);
    transition: all 0.3s ease;
    display: flex;
  }
  
  .social-links a:hover {
    color: var(--primary);
    transform: scale(1.15); 
  }
  
  .btn-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 8px; 
    background: var(--gradient-btn);
    color: var(--bg-white) !important;
    padding: 10px 24px;
    border-radius: 50px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-size: 0.9rem;
    border: none;
    cursor: pointer;
    box-shadow: 0 0 15px rgba(20, 184, 166, 0.4); 
    transition: all 0.3s ease;
  }

  .btn-whatsapp:hover {
    background: var(--gradient-btn-hover);
    box-shadow: 0 0 25px rgba(20, 184, 166, 0.7); 
    transform: translateY(-2px);
  }

  /* Ocultar el botón hamburguesa en escritorio */
  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 30px;
    height: 21px;
    background: transparent;
    border: none;
    cursor: pointer;
    z-index: 1001;
  }

  .menu-toggle .bar {
    height: 3px;
    width: 100%;
    background-color: var(--text-dark, #333);
    border-radius: 3px;
    transition: all 0.3s ease;
  }
  
  /* ESTILOS MÓVILES */
  @media (max-width: 968px) {
    .menu-toggle { 
      display: flex; 
    }
    
    .logo-img { height: 75px; } 
    .header.scrolled .logo-img { height: 55px; }

    /* Convertir el menú derecho en un menú desplegable */
    .nav-right {
      position: absolute;
      top: 100%;
      left: 0;
      width: 100%;
      background-color: var(--bg-white, #ffffff);
      flex-direction: column;
      align-items: center;
      padding: 0;
      gap: 1.5rem;
      box-shadow: 0 10px 15px rgba(0,0,0,0.1);
      
      /* Animación de ocultar/mostrar */
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      visibility: hidden;
      transition: all 0.4s ease-in-out;
      margin-top: 20px; /* Separación del header cuando está abierto */
    }

    .nav-right.active {
      max-height: 400px; /* Ajusta esto si el menú crece */
      padding: 2rem 0;
      opacity: 1;
      visibility: visible;
    }

    .nav-links {
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
    }

    .social-links {
      border-right: none;
      padding-right: 0;
      border-bottom: 1px solid #e5e7eb;
      padding-bottom: 1.5rem;
    }

    /* Animación del botón hamburguesa para que se vuelva una X */
    .menu-toggle.active .bar:nth-child(1) {
      transform: translateY(9px) rotate(45deg);
    }
    .menu-toggle.active .bar:nth-child(2) {
      opacity: 0;
    }
    .menu-toggle.active .bar:nth-child(3) {
      transform: translateY(-9px) rotate(-45deg);
    }
  }
</style>

<script>
  const header = document.getElementById('main-header');
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const navLinks = mobileMenu?.querySelectorAll('a');
  
  // Efecto Scroll
  if (header) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        header.classList.add('scrolled');
      } else {
        header.classList.remove('scrolled');
      }
    });
  }

  // Lógica del botón hamburguesa
  if (menuBtn && mobileMenu) {
    menuBtn.addEventListener('click', () => {
      menuBtn.classList.toggle('active');
      mobileMenu.classList.toggle('active');
    });

    // Cerrar el menú al hacer clic en cualquier enlace (ideal para móviles)
    navLinks?.forEach(link => {
      link.addEventListener('click', () => {
        menuBtn.classList.remove('active');
        mobileMenu.classList.remove('active');
      });
    });
  }
</script>