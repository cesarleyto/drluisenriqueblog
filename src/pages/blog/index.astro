---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

// Obtenemos los posts y los ordenamos por fecha
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Extraemos categorías únicas
const categories = ['Todos', ...new Set(posts.map(post => post.data.category || 'General'))];
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={`Blog | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		
		<main class="blog-container">
			<section class="blog-header">
				<h2>Actualidad en Ortopedia y Traumatología</h2>
				<p>Información técnica sobre patologías, avances quirúrgicos y recuperación funcional.</p>
			</section>

			<div class="filters">
				{categories.map((cat, index) => (
					<button class={`filter-btn ${index === 0 ? 'active' : ''}`} data-category={cat}>
						{cat}
					</button>
				))}
			</div>

			<div class="posts-grid">
				{posts.map((post) => (
					<article class="post-card" data-category={post.data.category || 'General'}>
						<a href={`/blog/${post.id.replace(/\.[^/.]+$/, "")}/`} class="card-link">
							<div class="image-wrapper">
								{post.data.heroImage && (
									<img src={post.data.heroImage} alt={post.data.title} />
								)}
							</div>
							<h3 class="post-title">{post.data.title}</h3>
							<span class="read-more">Leer ahora</span>
						</a>
					</article>
				))}
			</div>
		</main>

		<Footer />
	</body>
</html>

<style>
	/* Fondo Radial Turquesa Intenso */
	.blog-container {
		min-height: 100vh;
		padding: 80px 20px;
		background: radial-gradient(circle at center, rgba(20, 184, 166, 0.18) 0%, rgba(20, 184, 166, 0.05) 40%, rgba(255, 255, 255, 1) 80%);
	}

	.blog-header { text-align: center; margin-bottom: 3rem; }
	.blog-header h2 { font-size: 2.5rem; margin-bottom: 0.5rem; color: var(--primary); }
	.blog-header p { font-size: 1.1rem; color: var(--text-dark); max-width: 600px; margin: 0 auto; }

	/* Filtros */
	.filters {
		display: flex;
		justify-content: center;
		gap: 15px;
		margin-bottom: 3rem;
		flex-wrap: wrap;
	}
	.filter-btn {
		padding: 10px 25px;
		border-radius: 50px;
		border: none;
		background: #e2e8f0;
		cursor: pointer;
		font-weight: 600;
		transition: 0.3s;
	}
	.filter-btn.active {
		background: var(--gradient-btn);
		color: white;
	}

	/* Grid 3 columnas */
	.posts-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 30px;
		max-width: 1200px;
		margin: 0 auto;
	}

	/* Tarjeta */
	.post-card { 
		background: white; 
		border-radius: var(--radius-lg); 
		overflow: hidden; 
		box-shadow: var(--shadow-sm); 
		transition: 0.3s; 
		display: flex; 
		flex-direction: column; 
	}
	.post-card:hover { transform: translateY(-5px); box-shadow: var(--shadow-hover); }

	/* Ajuste 4:3 Horizontal */
	.image-wrapper { aspect-ratio: 4 / 3; overflow: hidden; }
	.image-wrapper img { width: 100%; height: 100%; object-fit: cover; transition: 0.6s; }
	.post-card:hover .image-wrapper img { transform: scale(1.1); }

	.post-title { 
		padding: 20px 15px 10px; 
		font-size: 1.25rem; 
		color: var(--text-dark);
		flex-grow: 1; 
	}
	
	.read-more { 
		display: inline-block; margin: 0 15px 20px; 
		color: var(--primary); font-weight: 700; font-size: 0.9rem;
		text-transform: uppercase; border-bottom: 2px solid var(--primary);
	}

	@media (max-width: 900px) { .posts-grid { grid-template-columns: repeat(2, 1fr); } }
	@media (max-width: 600px) { .posts-grid { grid-template-columns: 1fr; } }
</style>

<script>
	const buttons = document.querySelectorAll('.filter-btn');
	const posts = document.querySelectorAll('.post-card');

	buttons.forEach(btn => {
		btn.addEventListener('click', () => {
			buttons.forEach(b => b.classList.remove('active'));
			btn.classList.add('active');
			const cat = btn.getAttribute('data-category');
			posts.forEach(post => {
				if(cat === 'Todos' || post.getAttribute('data-category') === cat) post.style.display = 'block';
				else post.style.display = 'none';
			});
		});
	});
</script>